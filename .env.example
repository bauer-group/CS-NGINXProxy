# =============================================================================
# NGINX Proxy Manager - Environment Configuration
# =============================================================================
# Self-hosted reverse proxy with a web UI, powered by Nginx Proxy Manager,
# wrapped as a thin BAUER GROUP edition image that adds turnkey HTTP/3 (QUIC)
# and full CI/CD automation.
#
# NPM runs as the EDGE proxy directly on the host (no Traefik / no Coolify in
# front of it). It terminates TLS itself and forwards to your backends — which
# may live on other hosts. Use it for special cases and small environments where
# the Traefik stack is overkill and Kubernetes is not in play.
#
# NO SECRETS REQUIRED by default. On first start NPM shows a setup wizard that
# creates the administrator account; it is persisted in the data volume, so there
# is nothing in this file to rotate or leak. (Optionally you can provision the
# admin non-interactively via INITIAL_ADMIN_EMAIL / INITIAL_ADMIN_PASSWORD below.)
# Just:
#
#   cp .env.example .env        (Linux/macOS)
#   Copy-Item .env.example .env (Windows PowerShell)
#
# then review the ports / timezone below.
#
# Deployment:
#   Development (local image build): docker compose -f docker-compose.development.yml up -d --build
#   Production  (pre-built GHCR):    docker compose -f docker-compose.production.yml  up -d
# =============================================================================


# =============================================================================
# Stack Configuration
# =============================================================================

# Container / volume name prefix
STACK_NAME=nginxproxy_example_domain_com

# Container timezone (e.g. Europe/Berlin, Etc/UTC). Affects log timestamps and
# the certbot renewal scheduler.
TIME_ZONE=Etc/UTC


# =============================================================================
# Image Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Production image (pre-built from GHCR) — docker-compose.production.yml
# This is OUR published edition image, not the upstream jc21 one.
# -----------------------------------------------------------------------------
NGINX_PROXY_MANAGER_IMAGE=ghcr.io/bauer-group/cs-nginxproxy/nginx-proxy-manager
NGINX_PROXY_MANAGER_IMAGE_VERSION=latest

# -----------------------------------------------------------------------------
# Build base (development build) — upstream NPM image the edition wraps
# -----------------------------------------------------------------------------
NPM_REPOSITORY=jc21/nginx-proxy-manager
# Floating tag: tracks the latest NPM 2.x. Major is pinned to 2; the base-image
# monitor rebuilds when its digest moves. Pin to an exact tag (e.g. 2.15.1) only
# if you need bit-for-bit reproducibility.
NPM_VERSION=2


# =============================================================================
# Application Settings
# =============================================================================

# --- HTTP/3 (QUIC over UDP/443) ---------------------------------------------
# The edition image enables HTTP/3 by activating the QUIC support that is ALREADY
# compiled into the upstream nginx (OpenResty + OpenSSL 3.5). When true, every
# TLS-enabled proxy host additionally serves HTTP/3 and advertises it via the
# Alt-Svc header. HTTP/1.1 and HTTP/2 keep working unchanged.
#
# IMPORTANT: HTTP/3 also requires the UDP 443 port to be published (it is, in
# both compose files) AND your firewall to allow inbound UDP/443.
#
# Set to false to disable QUIC and serve HTTP/1.1 + HTTP/2 only.
NPM_HTTP3_ENABLE=true

# --- IPv6 --------------------------------------------------------------------
# Uncomment / set to true if IPv6 is NOT enabled on your host, otherwise nginx
# fails to bind the [::] listeners (including the QUIC ones).
DISABLE_IPV6=false

# --- SQLite database (internal, no external DB needed) -----------------------
# NPM uses an embedded SQLite database by default — no MySQL/MariaDB/Postgres
# required. This is the path INSIDE the container; it lives in the data volume.
# Leave as-is unless you have a specific reason to relocate it.
DB_SQLITE_FILE=/data/database.sqlite

# --- Optional: non-interactive admin provisioning ----------------------------
# Leave BOTH empty to use the first-run setup wizard (recommended, no secrets in
# .env). If BOTH are set, NPM creates this admin ONCE on a fresh database and
# skips the wizard — handy for automated deployments. These are CREDENTIALS:
# keep them out of version control and rotate via the UI after first login.
# To use them, also uncomment the matching lines in the compose file.
# INITIAL_ADMIN_EMAIL=admin@example.com
# INITIAL_ADMIN_PASSWORD=


# =============================================================================
# Port Settings (direct host binding — NPM is the edge)
# =============================================================================
# Format is <host-port>:<container-port>. The container ports are fixed by NPM
# (80, 443, 81); only the host side is configurable here.

# Public HTTP port  (host -> container 80)
PORT_HTTP=80

# Public HTTPS port (host -> container 443, TCP for H1/H2 + UDP for H3/QUIC)
PORT_HTTPS=443

# Admin web UI port (host -> container 81). NPM serves the admin UI over PLAIN
# HTTP on 81, so for production prefer binding it to a trusted interface only —
# e.g. set the published address to 127.0.0.1 in the compose file, or proxy the
# UI through NPM itself with a TLS host. Default host port is 8080.
PORT_ADMIN=8080
